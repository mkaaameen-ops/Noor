            numbers: [{ara: "١", name: "وَاحِد"}, {ara: "٢", name: "إِثْنَان"}, {ara: "٣", name: "ثَلَاثَة"}, {ara: "٤", name: "أَرْبَعَة"}, {ara: "٥", name: "خَمْسَة"}, {ara: "٦", name: "سِتَّة"}, {ara: "٧", name: "سَبْعَة"}, {ara: "٨", name: "ثَمَانِيَة"}, {ara: "٩", name: "تِسْعَة"}, {ara: "١٠", name: "عَشَرَة"}],
