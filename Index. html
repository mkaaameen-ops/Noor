            vegetables: [{emoji: "🥕", name: "جَزَر"}, {emoji: "🍅", name: "طَمَاطِم"}, {emoji: "🥒", name: "خِيَار"}, {emoji: "🥦", name: "بُرُوكْلِي"}, {emoji: "🥔", name: "بَطَاطِس"}, {emoji: "🍆", name: "بَاذِنْجَان"}, {emoji: "🌽", name: "ذُرَة"}, {emoji: "🫑", name: "فِلْفِل"}, {emoji: "🧄", name: "ثُوم"}, {emoji: "🧅", name: "بَصَل"}, {emoji: "🫛", name: "بَازِلَّاء"}]
        };

        const softColors = ["#6C5CE7", "#FF7675", "#55E6C1", "#F7D794", "#F19066", "#786FA6"];

        // ==============================
        // 2. AUDIO HELPERS
        // ==============================
        let audioCtx = null;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') audioCtx.resume();
            return audioCtx;
        }

        function playTone(freq, duration, type = 'sine', vol = 0.3) {
            const ctx = initAudio();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, ctx.currentTime);
            gain.gain.setValueAtTime(vol, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + duration);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + duration);
        }

        function playPopSound() { playTone(400, 0.12, 'sine', 0.3); }
        function playZapSound() { 
            const ctx = initAudio();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'square';
            osc.frequency.setValueAtTime(550, ctx.currentTime);
            osc.frequency.linearRampToValueAtTime(60, ctx.currentTime + 0.14);
            gain.gain.setValueAtTime(0.18, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.14);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + 0.14);
        }
        function playSwooshSound() {
            const ctx = initAudio();
            const bufferSize = ctx.sampleRate * 0.12;
            const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) { data[i] = Math.random() * 2 - 1; }
            const noise = ctx.createBufferSource();
            noise.buffer = buffer;
            const filter = ctx.createBiquadFilter();
            filter.type = 'lowpass';
            filter.frequency.setValueAtTime(400, ctx.currentTime);
            filter.frequency.exponentialRampToValueAtTime(1400, ctx.currentTime + 0.1);
            const gain = ctx.createGain();
            gain.gain.setValueAtTime(0.18, ctx.currentTime);
            gain.gain.linearRampToValueAtTime(0.01, ctx.currentTime + 0.12);
            noise.connect(filter);
            filter.connect(gain);
            gain.connect(ctx.destination);
            noise.start();
        }
        function playSliceSound() {
            const ctx = initAudio();
            const osc1 = ctx.createOscillator();
            const osc2 = ctx.createOscillator();
            const gain = ctx.createGain();
            osc1.type = 'sawtooth';
            osc1.frequency.setValueAtTime(900, ctx.currentTime);
            osc1.frequency.exponentialRampToValueAtTime(150, ctx.currentTime + 0.15);
            osc2.type = 'triangle';
            osc2.frequency.setValueAtTime(450, ctx.currentTime);
            osc2.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 0.15);
            gain.gain.setValueAtTime(0.25, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
            osc1.connect(gain);
            osc2.connect(gain);
            gain.connect(ctx.destination);
            osc1.start();
            osc2.start();
            osc1.stop(ctx.currentTime + 0.15);
            osc2.stop(ctx.currentTime + 0.15);
        }

        function speak(text) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'ar-SA';
                utterance.rate = 0.85;
                utterance.volume = 1.0;
                window.speechSynthesis.speak(utterance);
            }
        }

        function toArabicDigits(num) {
            return num.toString().split('').map(d => ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'][parseInt(d)]).join('');
        }

        // ==============================
        // 3. BACKGROUND MUSIC
        // ==============================
        let musicEnabled = false;
        let musicInterval = null;
        const musicToggle = document.getElementById('musicToggle');

        function toggleMusic() {
            musicEnabled = !musicEnabled;
            musicToggle.textContent = musicEnabled ? '🔊' : '🔇';
            if (musicEnabled) {
                startMusic();
            } else {
                stopMusic();
            }
        }

        function startMusic() {
            if (musicInterval) return;
            const ctx = initAudio();
            let noteIndex = 0;
            const notes = [523, 587, 659, 698, 784, 880, 988, 1047];
            musicInterval = setInterval(() => {
                if (!musicEnabled) return;
                const freq = notes[noteIndex % notes.length];
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.type = 'sine';
                osc.frequency.setValueAtTime(freq, ctx.currentTime);
                gain.gain.setValueAtTime(0.08, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.start();
                osc.stop(ctx.currentTime + 0.15);
                noteIndex++;
            }, 300);
        }

        function stopMusic() {
            if (musicInterval) {
                clearInterval(musicInterval);
                musicInterval = null;
            }
        }

        musicToggle.addEventListener('click', toggleMusic);

        // ==============================
        // 4. EDUCATIONAL GRID POPULATOR (FIXED)
        // ==============================
        function populateGrid(gridId, dataArray, colorOffset, isColorMode = false) {
            const grid = document.getElementById(gridId);
            grid.innerHTML = '';
            dataArray.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'interactive-item';
                div.setAttribute('role', 'button');
                // Determine display text
                let displayText;
                if (typeof item === 'string') {
                    displayText = item;
                } else if (item.ara) {
                    displayText = item.ara;          // For numbers
                } else if (item.emoji) {
                    displayText = item.emoji;        // For other categories
                } else {
                    displayText = '?';
                }
                div.innerText = displayText;

                // Background
                if (!isColorMode) {
                    div.style.backgroundColor = softColors[(index + colorOffset) % softColors.length];
                } else {
                    div.style.backgroundColor = item.hex;
                }

                // Click handler
                div.onpointerdown = (e) => {
                    e.preventDefault();
                    initAudio();
                    playPopSound();
                    speak(item.name || item);
                };
                grid.appendChild(div);
            });
        }

        // ==============================
        // 5. GAME ENGINE (shared loop)
        // ==============================
        let globalAnimFrame = null;
        let activeGames = [];

        function startGlobalLoop() {
            if (globalAnimFrame) return;
            function loop() {
                activeGames.forEach(game => {
                    if (game.isRunning) game.update();
                });
                globalAnimFrame = requestAnimationFrame(loop);
            }
            loop();
        }

        function stopGlobalLoop() {
            if (globalAnimFrame) {
                cancelAnimationFrame(globalAnimFrame);
                globalAnimFrame = null;
            }
        }

        // ==============================
        // 6. GAME CLASSES (unchanged)
        // ==============================
        class BalloonGame {
            constructor() {
                this.name = 'balloon';
                this.score = 0;
                this.isRunning = false;
                this.interval = null;
                this.activeBalloons = [];
                this.arena = document.getElementById('balloonArena');
                this.scoreEl = document.getElementById('balloonScore');
                this.overEl = document.getElementById('balloonGameOver');
                this.finalScoreEl = document.getElementById('balloonFinalScore');
                this.highScoreEl = document.getElementById('balloonHighScore');
                this.highScoreKey = 'balloonHigh';
                this.maxBalloons = 12;
            }

            start() {
                this.stop();
                this.isRunning = true;
                this.score = 0;
                this.overEl.classList.remove('active');
                this.updateScore();
                this.interval = setInterval(() => this.spawn(), Math.max(400, 1200 - this.score * 5));
                if (!activeGames.includes(this)) activeGames.push(this);
                startGlobalLoop();
            }

            stop() {
                this.isRunning = false;
                if (this.interval) { clearInterval(this.interval); this.interval = null; }
                this.activeBalloons.forEach(b => b.remove());
                this.activeBalloons = [];
                const idx = activeGames.indexOf(this);
                if (idx !== -1) activeGames.splice(idx, 1);
                if (activeGames.length === 0) stopGlobalLoop();
            }

            spawn() {
                if (!this.isRunning) return;
                const arena = this.arena;
                if (this.activeBalloons.length >= this.maxBalloons) return;
                const balloon = document.createElement('div');
                balloon.className = 'balloon';
                balloon.style.backgroundColor = softColors[Math.floor(Math.random() * softColors.length)];
                const randomSource = Math.random() > 0.5 ? DATA.letters : DATA.animals;
                const chosen = randomSource[Math.floor(Math.random() * randomSource.length)];
                balloon.innerText = typeof chosen === 'string' ? chosen : chosen.emoji;
                const speakName = typeof chosen === 'string' ? chosen : chosen.name;
                balloon.style.left = `${Math.random() * (arena.clientWidth - 80)}px`;
                balloon.style.top = `${arena.clientHeight + 20}px`;
                balloon.dataset.speed = (Math.random() * 2 + 1.5 + this.score * 0.03).toString();
                balloon.dataset.speak = speakName;
                balloon.onpointerdown = (e) => { e.preventDefault(); initAudio(); this.pop(balloon); };
                arena.appendChild(balloon);
                this.activeBalloons.push(balloon);
            }

            pop(balloon) {
                if (!this.activeBalloons.includes(balloon)) return;
                playPopSound();
                speak(balloon.dataset.speak);
                this.score++;
                this.updateScore();
                balloon.style.transform = "scale(1.4)";
                balloon.style.opacity = "0";
                balloon.style.transition = "transform 0.15s ease-out, opacity 0.15s ease-out";
                setTimeout(() => {
                    const idx = this.activeBalloons.indexOf(balloon);
                    if (idx !== -1) { this.activeBalloons.splice(idx, 1); }
                    balloon.remove();
                }, 150);
            }

            update() {
                const arena = this.arena;
                for (let i = this.activeBalloons.length - 1; i >= 0; i--) {
                    const b = this.activeBalloons[i];
                    let top = parseFloat(b.style.top);
                    top -= parseFloat(b.dataset.speed);
                    b.style.top = `${top}px`;
                    if (top < -120) {
                        b.remove();
                        this.activeBalloons.splice(i, 1);
                    }
                }
            }

            updateScore() {
                this.scoreEl.innerText = `النقاط: ${toArabicDigits(this.score)}`;
            }

            gameOver() {
                this.stop();
                const high = parseInt(localStorage.getItem(this.highScoreKey) || '0');
                if (this.score > high) localStorage.setItem(this.highScoreKey, this.score.toString());
                this.finalScoreEl.innerText = `لقد جمعت: ${toArabicDigits(this.score)}`;
                this.highScoreEl.innerText = `أعلى نتيجة: ${toArabicDigits(Math.max(high, this.score))}`;
                this.overEl.classList.add('active');
                speak(`انتهى اللعب وجمعت ${this.score} نقطة`);
            }
        }

        class NinjaGame {
            constructor() {
                this.name = 'ninja';
                this.score = 0;
                this.timeLeft = 30;
                this.isRunning = false;
                this.interval = null;
                this.timerInterval = null;
                this.activeFruits = [];
                this.arena = document.getElementById('ninjaArena');
                this.scoreEl = document.getElementById('ninjaScore');
                this.timerEl = document.getElementById('ninjaTimer');
                this.overEl = document.getElementById('ninjaGameOver');
                this.finalScoreEl = document.getElementById('ninjaFinalScore');
                this.highScoreEl = document.getElementById('ninjaHighScore');
                this.highScoreKey = 'ninjaHigh';
                this.isDrawing = false;
                this.lastX = 0;
                this.lastY = 0;
                this.lastSlashPlay = 0;
                this.setupPointer();
            }

            setupPointer() {
                const arena = this.arena;
                arena.onpointerdown = (e) => {
                    e.preventDefault();
                    initAudio();
                    this.isDrawing = true;
                    const bounds = arena.getBoundingClientRect();
                    this.lastX = e.clientX - bounds.left;
                    this.lastY = e.clientY - bounds.top;
                    this.processPointer(e.clientX, e.clientY);
                };
                arena.onpointermove = (e) => {
                    if (this.isDrawing) this.processPointer(e.clientX, e.clientY);
                };
                arena.onpointerup = () => { this.isDrawing = false; };
            }

            processPointer(clientX, clientY) {
                const bounds = this.arena.getBoundingClientRect();
                const mx = clientX - bounds.left;
                const my = clientY - bounds.top;
                if (this.isDrawing && (this.lastX !== mx || this.lastY !== my)) {
                    this.createTrail(this.lastX, this.lastY, mx, my);
                    const now = Date.now();
                    if (now - this.lastSlashPlay > 70) { playSwooshSound(); this.lastSlashPlay = now; }
                    for (const fruit of this.activeFruits) {
                        if (fruit.dataset.sliced === "true") continue;
                        const fx = parseFloat(fruit.style.left) + 40;
                        const fy = parseFloat(fruit.style.top) + 40;
                        if (Math.hypot(mx - fx, my - fy) < 55) this.sliceFruit(fruit);
                    }
                }
                this.lastX = mx;
                this.lastY = my;
            }

            createTrail(x1, y1, x2, y2) {
                const dist = Math.hypot(x2 - x1, y2 - y1);
                if (dist < 3) return;
                const angle = Math.atan2(y2 - y1, x2 - x1) * (180 / Math.PI);
                const trail = document.createElement('div');
                trail.className = 'sword-trail';
                trail.style.width = `${dist}px`;
                trail.style.left = `${x1}px`;
                trail.style.top = `${y1}px`;
                trail.style.transform = `rotate(${angle}deg)`;
                this.arena.appendChild(trail);
                setTimeout(() => {
                    trail.style.opacity = '0';
                    setTimeout(() => trail.remove(), 120);
                }, 20);
            }

            sliceFruit(fruit) {
                fruit.dataset.sliced = "true";
                this.score++;
                this.updateScore();
                playSliceSound();
                speak(fruit.dataset.name);
                const whole = fruit.querySelector('.fruit-whole');
                if (whole) whole.remove();
                const emoji = fruit.dataset.emoji;
                const leftHalf = document.createElement('div');
                leftHalf.className = 'fruit-half-left';
                leftHalf.innerText = emoji;
                const rightHalf = document.createElement('div');
                rightHalf.className = 'fruit-half-right';
                rightHalf.innerText = emoji;
                fruit.appendChild(leftHalf);
                fruit.appendChild(rightHalf);
                fruit.dataset.vy = (parseFloat(fruit.dataset.vy) - 2).toString();
            }

            start() {
                this.stop();
                this.isRunning = true;
                this.score = 0;
                this.timeLeft = 30;
                this.overEl.classList.remove('active');
                this.updateScore();
                this.updateTimer();
                this.interval = setInterval(() => this.spawn(), Math.max(400, 800 - this.score * 3));
                this.timerInterval = setInterval(() => {
                    this.timeLeft--;
                    this.updateTimer();
                    if (this.timeLeft <= 0) this.gameOver();
                }, 1000);
                if (!activeGames.includes(this)) activeGames.push(this);
                startGlobalLoop();
            }

            stop() {
                this.isRunning = false;
                if (this.interval) { clearInterval(this.interval); this.interval = null; }
                if (this.timerInterval) { clearInterval(this.timerInterval); this.timerInterval = null; }
                this.activeFruits.forEach(f => f.remove());
                this.activeFruits = [];
                const idx = activeGames.indexOf(this);
                if (idx !== -1) activeGames.splice(idx, 1);
                if (activeGames.length === 0) stopGlobalLoop();
            }

            spawn() {
                if (!this.isRunning) return;
                const arena = this.arena;
                const fruitItem = DATA.fruits[Math.floor(Math.random() * DATA.fruits.length)];
                const wrapper = document.createElement('div');
                wrapper.className = 'ninja-fruit';
                const whole = document.createElement('div');
                whole.className = 'fruit-whole';
                whole.innerText = fruitItem.emoji;
                wrapper.appendChild(whole);
                const startX = Math.random() * (arena.clientWidth - 100) + 10;
                wrapper.style.left = `${startX}px`;
                wrapper.style.top = `${arena.clientHeight}px`;
                wrapper.dataset.name = fruitItem.name;
                wrapper.dataset.emoji = fruitItem.emoji;
                wrapper.dataset.sliced = "false";
                wrapper.dataset.vx = ((Math.random() - 0.5) * 4).toString();
                wrapper.dataset.vy = (-(Math.random() * 3 + 12 + this.score * 0.1)).toString();
                wrapper.dataset.rot = "0";
                wrapper.dataset.halfX = "0";
                wrapper.dataset.halfY = "0";
                wrapper.dataset.halfRot = "0";
                arena.appendChild(wrapper);
                this.activeFruits.push(wrapper);
            }

            update() {
                const gravity = 0.28;
                for (let i = this.activeFruits.length - 1; i >= 0; i--) {
                    const fruit = this.activeFruits[i];
                    const sliced = fruit.dataset.sliced === "true";
                    let curX = parseFloat(fruit.style.left);
                    let curY = parseFloat(fruit.style.top);
                    let vx = parseFloat(fruit.dataset.vx);
                    let vy = parseFloat(fruit.dataset.vy);
                    vy += gravity;
                    curX += vx;
                    curY += vy;
                    fruit.style.left = `${curX}px`;
                    fruit.style.top = `${curY}px`;
                    fruit.dataset.vy = vy.toString();
                    if (!sliced) {
                        let rot = (parseFloat(fruit.dataset.rot) + 2.5) % 360;
                        fruit.dataset.rot = rot.toString();
                        fruit.querySelector('.fruit-whole').style.transform = `rotate(${rot}deg)`;
                    } else {
                        let hX = parseFloat(fruit.dataset.halfX) + 3;
                        let hY = parseFloat(fruit.dataset.halfY) + gravity * 1.5;
                        let hRot = parseFloat(fruit.dataset.halfRot) + 5;
                        fruit.dataset.halfX = hX.toString();
                        fruit.dataset.halfY = hY.toString();
                        fruit.dataset.halfRot = hRot.toString();
                        const leftHalf = fruit.querySelector('.fruit-half-left');
                        const rightHalf = fruit.querySelector('.fruit-half-right');
                        if (leftHalf && rightHalf) {
                            leftHalf.style.transform = `translate(${-hX}px, ${hY}px) rotate(${-hRot}deg)`;
                            rightHalf.style.transform = `translate(${hX}px, ${hY}px) rotate(${hRot}deg)`;
                        }
                    }
                    if (curY > this.arena.clientHeight + 120) {
                        fruit.remove();
                        this.activeFruits.splice(i, 1);
                    }
                }
            }

            updateScore() {
                this.scoreEl.innerText = `الفواكه: ${toArabicDigits(this.score)}`;
            }
            updateTimer() {
                this.timerEl.innerText = `الوقت: ${toArabicDigits(this.timeLeft)}`;
            }

            gameOver() {
                this.stop();
                const high = parseInt(localStorage.getItem(this.highScoreKey) || '0');
                if (this.score > high) localStorage.setItem(this.highScoreKey, this.score.toString());
                this.finalScoreEl.innerText = `لَقَدْ جَمَعْتَ: ${toArabicDigits(this.score)}`;
                this.highScoreEl.innerText = `أعلى نتيجة: ${toArabicDigits(Math.max(high, this.score))}`;
                this.overEl.classList.add('active');
                speak(`انتهى الوقت وجمعت ${this.score} فاكهة`);
            }
        }

        class FlyGame {
            constructor() {
                this.name = 'fly';
                this.score = 0;
                this.timeLeft = 30;
                this.isRunning = false;
                this.interval = null;
                this.timerInterval = null;
                this.activeFlies = [];
                this.arena = document.getElementById('flyArena');
                this.scoreEl = document.getElementById('flyScore');
                this.timerEl = document.getElementById('flyTimer');
                this.overEl = document.getElementById('flyGameOver');
                this.finalScoreEl = document.getElementById('flyFinalScore');
                this.highScoreEl = document.getElementById('flyHighScore');
                this.highScoreKey = 'flyHigh';
                this.maxFlies = 6;
            }

            start() {
                this.stop();
                this.isRunning = true;
                this.score = 0;
                this.timeLeft = 30;
                this.overEl.classList.remove('active');
                this.updateScore();
                this.updateTimer();
                this.interval = setInterval(() => this.spawn(), Math.max(500, 900 - this.score * 4));
                this.timerInterval = setInterval(() => {
                    this.timeLeft--;
                    this.updateTimer();
                    if (this.timeLeft <= 0) this.gameOver();
                }, 1000);
                if (!activeGames.includes(this)) activeGames.push(this);
                startGlobalLoop();
            }

            stop() {
                this.isRunning = false;
                if (this.interval) { clearInterval(this.interval); this.interval = null; }
                if (this.timerInterval) { clearInterval(this.timerInterval); this.timerInterval = null; }
                this.activeFlies.forEach(f => f.remove());
                this.activeFlies = [];
                const idx = activeGames.indexOf(this);
                if (idx !== -1) activeGames.splice(idx, 1);
                if (activeGames.length === 0) stopGlobalLoop();
            }

            spawn() {
                if (!this.isRunning || this.activeFlies.length >= this.maxFlies) return;
                const arena = this.arena;
                const fly = document.createElement('div');
                fly.className = 'fly-bug';
                fly.innerText = '🦟';
                fly.dataset.caught = "false";
                fly.dataset.spawnTime = Date.now().toString();
                fly.style.left = `${Math.random() * (arena.clientWidth - 70)}px`;
                fly.style.top = `${Math.random() * (arena.clientHeight - 70)}px`;
                fly.dataset.seed = Math.random().toString();
                fly.dataset.angle = (Math.random() * Math.PI * 2).toString();
                const speed = Math.random() * 2 + 2.8 + this.score * 0.04;
                fly.dataset.speed = speed.toString();
                fly.onpointerdown = (e) => { e.preventDefault(); e.stopPropagation(); initAudio(); this.catchFly(fly); };
                arena.appendChild(fly);
                this.activeFlies.push(fly);
            }

            catchFly(fly) {
                if (fly.dataset.caught === "true") return;
                fly.dataset.caught = "true";
                this.score++;
                this.updateScore();
                playZapSound();
                speak("ذُبَابَة");
                fly.innerText = '💥';
                fly.style.transform = "scale(1.4)";
                fly.style.opacity = "0";
                setTimeout(() => {
                    const idx = this.activeFlies.indexOf(fly);
                    if (idx !== -1) this.activeFlies.splice(idx, 1);
                    fly.remove();
                }, 100);
            }

            update() {
                const now = Date.now();
                const arena = this.arena;
                for (let i = this.activeFlies.length - 1; i >= 0; i--) {
                    const fly = this.activeFlies[i];
                    const age = now - parseFloat(fly.dataset.spawnTime);
                    if (age > 6000 && fly.dataset.caught === "false") {
                        fly.remove();
                        this.activeFlies.splice(i, 1);
                        continue;
                    }
                    if (fly.dataset.caught === "true") continue;
                    let curX = parseFloat(fly.style.left);
                    let curY = parseFloat(fly.style.top);
                    let angle = parseFloat(fly.dataset.angle);
                    let speed = parseFloat(fly.dataset.speed);
                    let seed = parseFloat(fly.dataset.seed);
                    angle += Math.sin(performance.now() * 0.08 + seed) * 0.3;
                    curX += Math.cos(angle) * speed;
                    curY += Math.sin(angle) * speed;
                    if (curX < 0 || curX > arena.clientWidth - 70) angle = Math.PI - angle;
                    if (curY < 0 || curY > arena.clientHeight - 70) angle = -angle;
                    fly.dataset.angle = angle.toString();
                    fly.style.left = `${Math.max(0, Math.min(arena.clientWidth - 70, curX))}px`;
                    fly.style.top = `${Math.max(0, Math.min(arena.clientHeight - 70, curY))}px`;
                    fly.style.transform = `scale(${1 + Math.sin(performance.now() * 0.5) * 0.1}) rotate(${angle * (180/Math.PI) + 90}deg)`;
                }
            }

            updateScore() {
                this.scoreEl.innerText = `الذباب: ${toArabicDigits(this.score)}`;
            }
            updateTimer() {
                this.timerEl.innerText = `الوقت: ${toArabicDigits(this.timeLeft)}`;
            }

            gameOver() {
                this.stop();
                const high = parseInt(localStorage.getItem(this.highScoreKey) || '0');
                if (this.score > high) localStorage.setItem(this.highScoreKey, this.score.toString());
                this.finalScoreEl.innerText = `لَقَدْ صِدْتَ: ${toArabicDigits(this.score)}`;
                this.highScoreEl.innerText = `أعلى نتيجة: ${toArabicDigits(Math.max(high, this.score))}`;
                this.overEl.classList.add('active');
                speak(`انتهى الوقت وصدت ${this.score} ذبابة`);
            }
        }

        // ==============================
        // 7. INSTANTIATE GAMES
        // ==============================
        const games = {
            balloon: new BalloonGame(),
            ninja: new NinjaGame(),
            fly: new FlyGame()
        };

        // ==============================
        // 8. VIEW SWITCHING
        // ==============================
        function switchView(viewId) {
            initAudio();
            Object.values(games).forEach(g => g.stop());
            if (mediaRecorder && mediaRecorder.state === 'recording') mediaRecorder.stop();

            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');

            if (viewId === 'balloonGameView') games.balloon.start();
            else if (viewId === 'ninjaGameView') games.ninja.start();
            else if (viewId === 'flyGameView') games.fly.start();
            else if (viewId === 'menuView') speak("القَائِمَة الرَّئِيسِيَّة");
            else if (viewId === 'studioVoiceView') speak("مغير الأصوات السحري");

            forceAutoFullScreenLock();
        }

        // ==============================
        // 9. VOICE STUDIO (unchanged)
        // ==============================
        let mediaRecorder = null;
        let audioChunks = [];
        let selectedMode = 'parrot';
        let silenceTimeout = null;
        const actionBtn = document.getElementById('actionBtn');
        const mainEmoji = document.getElementById('mainEmoji');
        const equalizer = document.getElementById('equalizer');
        const statusTxt = document.getElementById('statusTxt');

        function changeCharacter(mode, emoji, color) {
            if (mediaRecorder && mediaRecorder.state === 'recording') return;
            selectedMode = mode;
            mainEmoji.textContent = emoji;
            document.querySelectorAll('.char-card').forEach(c => c.classList.remove('active'));
            document.getElementById(`card-${mode}`).classList.add('active');
            document.documentElement.style.setProperty('--primary-color', color);
            statusTxt.textContent = `جاهز للتحدث بصوت الـ ${document.getElementById(`card-${mode}`).querySelector('.char-name').textContent}`;
        }

        async function processAndPlayVoice() {
            if (!mediaRecorder || mediaRecorder.state !== 'recording') return;
            mediaRecorder.stop();
        }

        actionBtn.addEventListener('click', async () => {
            initAudio();
            if (!mediaRecorder || mediaRecorder.state === 'inactive') {
                audioChunks = [];
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    mediaRecorder = new MediaRecorder(stream);

                    const audioContextAnalysis = new (window.AudioContext || window.webkitAudioContext)();
                    const sourceAnalyst = audioContextAnalysis.createMediaStreamSource(stream);
                    const analyser = audioContextAnalysis.createAnalyser();
                    analyser.fftSize = 256;
                    sourceAnalyst.connect(analyser);
                    const bufferLength = analyser.frequencyBinCount;
                    const dataArray = new Uint8Array(bufferLength);

                    let silenceCounter = 0;
                    const SILENCE_THRESHOLD = 15;
                    const MAX_SILENCE_FRAMES = 30;

                    function checkSilence() {
                        if (!mediaRecorder || mediaRecorder.state !== 'recording') {
                            audioContextAnalysis.close();
                            return;
                        }
                        analyser.getByteFrequencyData(dataArray);
                        let sum = 0;
                        for (let i = 0; i < bufferLength; i++) sum += dataArray[i];
                        let avg = sum / bufferLength;
                        if (avg > SILENCE_THRESHOLD) {
                            silenceCounter = 0;
                        } else {
                            silenceCounter++;
                            if (silenceCounter >= MAX_SILENCE_FRAMES) {
                                if (mediaRecorder.state === 'recording') processAndPlayVoice();
                            }
                        }
                        requestAnimationFrame(checkSilence);
                    }

                    mediaRecorder.ondataavailable = e => { if (e.data.size > 0) audioChunks.push(e.data); };

                    mediaRecorder.onstop = async () => {
                        if (silenceTimeout) clearTimeout(silenceTimeout);
                        statusTxt.textContent = "يتم معالجة الصوت السحري... ✨";
                        mainEmoji.className = "main-emoji talk-animation";
                        equalizer.classList.remove('active');

                        stream.getTracks().forEach(track => track.stop());
                        audioContextAnalysis.close();

                        if (audioChunks.length === 0) { resetStudioState(); return; }

                        const audioBlob = new Blob(audioChunks, { type: 'audio/mp3' });
                        const arrayBuffer = await audioBlob.arrayBuffer();
                        const playbackCtx = new (window.AudioContext || window.webkitAudioContext)();

                        try {
                            const audioBuffer = await playbackCtx.decodeAudioData(arrayBuffer);
                            const source = playbackCtx.createBufferSource();
                            source.buffer = audioBuffer;

                            if (selectedMode === 'parrot') { source.playbackRate.value = 1.45; source.connect(playbackCtx.destination); }
                            else if (selectedMode === 'cat') { source.playbackRate.value = 1.25; let biquad = playbackCtx.createBiquadFilter(); biquad.type = "highpass"; biquad.frequency.value = 400; source.connect(biquad); biquad.connect(playbackCtx.destination); }
                            else if (selectedMode === 'mouse') { source.playbackRate.value = 1.65; let biquad = playbackCtx.createBiquadFilter(); biquad.type = "highpass"; biquad.frequency.value = 550; source.connect(biquad); biquad.connect(playbackCtx.destination); }
                            else if (selectedMode === 'lion') { source.playbackRate.value = 0.65; let biquad = playbackCtx.createBiquadFilter(); biquad.type = "lowpass"; biquad.frequency.value = 750; source.connect(biquad); biquad.connect(playbackCtx.destination); }
                            else if (selectedMode === 'curlew') { source.playbackRate.value = 1.35; let osc = playbackCtx.createOscillator(); let gain = playbackCtx.createGain(); osc.type = 'triangle'; osc.frequency.value = 12; gain.gain.value = 0.5; let filter = playbackCtx.createBiquadFilter(); filter.type = 'bandpass'; filter.frequency.value = 1800; osc.connect(gain); gain.connect(filter.frequency); source.connect(filter); filter.connect(playbackCtx.destination); osc.start(); }
                            else if (selectedMode === 'robot') { source.playbackRate.value = 1.05; let filter = playbackCtx.createBiquadFilter(); filter.type = 'peaking'; filter.frequency.value = 1500; source.connect(filter); filter.connect(playbackCtx.destination); }
                            else if (selectedMode === 'giant') { source.playbackRate.value = 0.72; source.connect(playbackCtx.destination); }

                            source.start(0);
                            source.onended = () => { resetStudioState(); playbackCtx.close(); };
                        } catch(e) { resetStudioState(); playbackCtx.close(); }
                    };

                    mediaRecorder.start();
                    checkSilence();
                    actionBtn.textContent = "🛑 توقف واسمع النتيجة";
                    actionBtn.classList.add('recording');
                    statusTxt.textContent = "استمع إليك الآن... تكلم وسأرد عليك تلقائياً!";
                    mainEmoji.className = "main-emoji pulse-animation";
                    equalizer.classList.add('active');
                } catch (err) {
                    statusTxt.textContent = "تنبيه: يجب تفعيل صلاحية المايكروفون من الإعدادات.";
                }
            } else {
                processAndPlayVoice();
            }
        });

        function resetStudioState() {
            mainEmoji.className = "main-emoji";
            statusTxt.textContent = "اضغط وجرب شخصية أخرى!";
            actionBtn.textContent = "🎤 اضغط وتحدث";
            actionBtn.classList.remove('recording');
        }

        // ==============================
        // 10. UTILITIES
        // ==============================
        function forceAutoFullScreenLock() {
            const targetHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight;
            document.documentElement.style.setProperty('--app-height', `${targetHeight}px`);
            window.scrollTo(0, 0);
        }

        function setupIOSHardwareLocks() {
            document.addEventListener('contextmenu', e => e.preventDefault());
            document.addEventListener('touchmove', function(e) {
                if (!e.target.closest('.game-container') && !e.target.closest('.game-canvas-container') && !e.target.closest('.studio-card'))
                    e.preventDefault();
            }, { passive: false });
        }

        // ==============================
        // 11. INIT
        // ==============================
        function initApp() {
            forceAutoFullScreenLock();
            window.addEventListener('resize', forceAutoFullScreenLock);
            window.addEventListener('orientationchange', forceAutoFullScreenLock);

            populateGrid('lettersGrid', DATA.letters, 0);
            populateGrid('numbersGrid', DATA.numbers, 2);
            populateGrid('colorsGrid', DATA.colors, 0, true);
            populateGrid('shapesGrid', DATA.shapes, 6);
            populateGrid('animalsGrid', DATA.animals, 4);
            populateGrid('birdsGrid', DATA.birds, 1);
            populateGrid('fruitsGrid', DATA.fruits, 3);
            populateGrid('vegetablesGrid', DATA.vegetables, 5);

            setupIOSHardwareLocks();
            switchView('menuView');

            document.addEventListener('pointerdown', () => initAudio(), { once: true });
        }

        window.onload = initApp;
    </script>
